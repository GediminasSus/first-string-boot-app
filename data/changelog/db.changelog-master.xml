<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
           http://www.liquibase.org/xml/ns/dbchangelog
           https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1-create-students-table" author="student">
        <createTable tableName="students">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="age" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="active" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="gender" type="CHAR(1)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2-create-subjects-table" author="student">
        <createTable tableName="subjects">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="grade" type="FLOAT">
                <constraints nullable="false"/>
            </column>
            <column name="credits" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="student_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="subjects"
                baseColumnNames="student_id"
                constraintName="fk_subject_student"
                referencedTableName="students"
                referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="3-insert-student" author="student">
        <insert tableName="students">
            <column name="id" valueNumeric="1"/>
            <column name="name" value="John Smith"/>
            <column name="age" valueNumeric="21"/>
            <column name="active" valueBoolean="true"/>
            <column name="gender" value="M"/>
        </insert>
    </changeSet>

